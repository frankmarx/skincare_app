{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend: Local",
            "type": "shell",
            "command": "chalice local",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "group": "app-group",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Frontend: Dev",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "group": "app-group",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Run App",
            "dependsOn": [
                "Backend: Local",
                "Frontend: Dev"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}
